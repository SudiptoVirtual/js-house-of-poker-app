# Copy this file to `.env.local` for local overrides while developing with Expo.
# EAS profiles set APP_ENV automatically. For local runs, keep this as development
# or override it in your shell when testing a preview/production config.
APP_ENV=development

# Set this to the poker-backend origin.
EXPO_PUBLIC_BASE_URL=http://localhost:5000
EXPO_PUBLIC_API_TIMEOUT=15000
# Optional poker transport override. Leave as `local` for in-app local gameplay.
# To test the unified Socket.IO poker-backend locally, set transport to `socket`
# and keep both backend/socket URLs on the same origin.
EXPO_PUBLIC_POKER_TRANSPORT=local
EXPO_PUBLIC_POKER_BACKEND_URL=http://localhost:5000
EXPO_PUBLIC_POKER_SOCKET_URL=http://localhost:5000
EXPO_PUBLIC_POKER_SOCKET_PROTOCOL=table-v1

# Preview/production unified backend values are checked in via `.env.preview`,
# `.env.production`, and `eas.json`. Keep local development on localhost by
# setting EXPO_PUBLIC_BASE_URL=http://localhost:5000 in `.env.local` or your shell.
# Firebase web app config from Project Settings -> General -> Your apps.
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
# Google OAuth client IDs used by Expo AuthSession.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
