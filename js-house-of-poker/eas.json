{
  "cli": {
    "version": ">= 18.8.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "@google_android_client_id",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "@google_ios_client_id",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "@google_web_client_id"
      },
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_BASE_URL": "@poker_backend_url",
        "EXPO_PUBLIC_POKER_BACKEND_URL": "@poker_backend_url",
        "EXPO_PUBLIC_POKER_SOCKET_URL": "@poker_backend_url",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "@google_android_client_id",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "@google_ios_client_id",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "@google_web_client_id"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_POKER_TRANSPORT": "socket",
        "EXPO_PUBLIC_BASE_URL": "@poker_backend_url",
        "EXPO_PUBLIC_POKER_BACKEND_URL": "@poker_backend_url",
        "EXPO_PUBLIC_POKER_SOCKET_URL": "@poker_backend_url",
        "EXPO_PUBLIC_POKER_SOCKET_PROTOCOL": "table-v1",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "@google_android_client_id",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "@google_ios_client_id",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "@google_web_client_id"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
