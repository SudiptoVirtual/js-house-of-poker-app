NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb://replace-with-production-mongodb-uri
JWT_SECRET=replace-with-a-long-random-production-secret
# Comma-separated browser origins allowed to call the API and Socket.IO server.
# Include the production web origin and any Expo-hosted preview/web origins you deploy.
ALLOWED_ORIGINS=https://www.jshouseofpoker.com

# Optional Firebase Admin credentials used to verify Firebase ID tokens.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Optional poker defaults.
POKER_SMALL_BLIND=10
POKER_BIG_BLIND=20
POKER_DEFAULT_BUY_IN=1000
