PORT=5000
# Local development origins are allowed automatically when NODE_ENV is not production.
# Add any extra Expo/web origins here as a comma-separated list.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://127.0.0.1:19006
MONGODB_URI=mongodb://localhost:27017/house-of-poker
JWT_SECRET=replace-with-a-long-random-secret
USER_LOGIN_MAX_ATTEMPTS=5
USER_LOGIN_LOCK_MINUTES=15
POKER_SMALL_BLIND=10
POKER_BIG_BLIND=20
POKER_DEFAULT_BUY_IN=1000
# Firebase Admin credentials used to verify Firebase ID tokens on the backend.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# Optional alternative to the three variables above:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# Feed promotion payments. Local development can use mock/manual by setting
# FEED_PROMOTION_PAYMENT_PROVIDER, but production must explicitly use Stripe.
FEED_PROMOTION_PAYMENT_PROVIDER=mock
# STRIPE_SECRET_KEY=sk_test_replace-with-stripe-secret-key
# FEED_PROMOTION_SUCCESS_URL=http://localhost:8081/feed/promotion/success
# FEED_PROMOTION_CANCEL_URL=http://localhost:8081/feed/promotion/cancel
# FEED_PROMOTION_STRIPE_WEBHOOK_SECRET=whsec_replace-with-stripe-webhook-secret
